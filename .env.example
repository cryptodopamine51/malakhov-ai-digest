APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000

DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/malakhov_ai_digest

BOT_TOKEN=replace-with-telegram-bot-token
BOT_POLLING_ENABLED=false
SITE_LEADS_CHAT_ID=

OPENAI_API_KEY=
OPENAI_SUMMARY_ENABLED=true
OPENAI_SUMMARY_MODEL=gpt-5-mini
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_SUMMARY_TIMEOUT_SECONDS=20

# Cloudflare R2 — хранилище обложек/инлайн-картинок (S3-совместимое, egress бесплатен).
# Нужно только для скриптов, ЗАГРУЖАЮЩИХ изображения (cron ai-covers.yml + backfill/migrate).
# Публичному сайту не нужно: он читает обложки по URL из articles.cover_image_url.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# Адаптивные cover-варианты (R2 + <img srcset>). По умолчанию выключено.
# Включать только ПОСЛЕ полного прогона scripts/backfill-cover-variants.ts (см. docs/OPERATIONS.md).
NEXT_PUBLIC_R2_IMAGE_VARIANTS=
# Нужно только при переезде R2 на custom domain (host ≠ *.r2.dev), чтобы клиентский isR2ImageUrl знал host.
NEXT_PUBLIC_R2_PUBLIC_BASE_URL=

DEFAULT_TIMEZONE=Europe/Moscow

INGESTION_INTERVAL_MINUTES=30
INGESTION_SCHEDULER_ENABLED=true
INGESTION_HTTP_TIMEOUT_SECONDS=10
RSS_FRESHNESS_WINDOW_MINUTES=30
OFFICIAL_BLOG_FRESHNESS_WINDOW_MINUTES=20
WEBSITE_FRESHNESS_WINDOW_MINUTES=90

PROCESS_EVENTS_INTERVAL_MINUTES=15
PROCESS_EVENTS_SCHEDULER_ENABLED=true
RAW_SHORTLIST_MAX_AGE_HOURS=336
RAW_SHORTLIST_MIN_TITLE_LENGTH=12
RAW_SHORTLIST_MIN_TITLE_TOKENS=3
RAW_SHORTLIST_MIN_TEXT_LENGTH=20
RAW_SHORTLIST_DUPLICATE_RECENT_DAYS=14
EVENT_LLM_SHORTLIST_THRESHOLD=58
EVENT_LLM_SHORTLIST_SECONDARY_THRESHOLD=48

DAILY_DIGEST_HOUR=9
DAILY_DIGEST_MINUTE=0
WEEKLY_DIGEST_WEEKDAY=mon
WEEKLY_DIGEST_HOUR=9
WEEKLY_DIGEST_MINUTE=15
DIGEST_SEND_DELAY_MINUTES=5
SCHEDULER_MISFIRE_GRACE_SECONDS=900

TELEGRAM_DAILY_MIN_RANKING_SCORE=58
TELEGRAM_DAILY_FALLBACK_MIN_SCORE=45
TELEGRAM_DAILY_TOTAL_CAP=5
TELEGRAM_DAILY_WEAK_DAY_TOTAL_CAP=3
TELEGRAM_MODELS_SERVICES_CAP=2
TELEGRAM_TOOLS_CODING_CAP=2
TELEGRAM_INVESTMENTS_MARKET_CAP=2
TELEGRAM_AI_RUSSIA_CAP=2

RUSSIA_RELEVANCE_MIN_SCORE=0.58
RUSSIA_SECTION_MIN_RANKING_SCORE=48
RUSSIA_SOURCE_REVIEW_MAX_ERROR_RATE=0.45
RUSSIA_SOURCE_REVIEW_MIN_RAW_ITEMS=1

RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
LEADS_EMAIL_TO=
LEADS_EMAIL_FROM=
LEADS_EMAIL_FROM_NAME=

# Legacy Node / Supabase layer
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
DEEPL_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
