DEEPSEEK_WRITER_MODEL=deepseek-v4-flash
DEEPSEEK_REPAIR_MODEL=deepseek-v4-flash
DEEPSEEK_DAILY_BUDGET_USD=0.25
DEEPSEEK_TELEGRAM_CAPTION_MODEL=deepseek-v4-flash
DEEPSEEK_TELEGRAM_CAPTION_DAILY_BUDGET_USD=0.05
DEEPSEEK_TELEGRAM_CAPTION_TIMEOUT_MS=45000
EDITORIAL_SOURCE_TEXT_CAP=15000
QUALITY_JUDGE_MODEL=claude-haiku-4-5
OPENAI_IMAGE_DAILY_BUDGET_USD=1
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_OWNER_USER_ID=
TELEGRAM_OWNER_USERNAME=
TELEGRAM_FEEDBACK_SECRET_TOKEN=
